/* Generated by chezmoi — edit themes/<name>/<subtheme>.yaml */
@define-color base           {{ .colors.base }};
@define-color surface        {{ .colors.surface }};
@define-color midpoint       {{ .colors.midpoint }};
@define-color overlay        {{ .colors.overlay }};
@define-color muted          {{ .colors.muted }};
@define-color subtle         {{ .colors.subtle }};
@define-color text           {{ .colors.text }};
@define-color love           {{ .colors.red }};
@define-color gold           {{ .colors.yellow }};
@define-color pine           {{ .colors.green }};
@define-color foam           {{ .colors.teal }};
@define-color iris           {{ .colors.purple }};
@define-color rose           {{ .colors.accent }};
@define-color highlightLow   {{ .colors.highlight_low }};
@define-color highlightMed   {{ .colors.highlight_mid }};
@define-color highlightHigh  {{ .colors.highlight_high }};

/* main colors */

@define-color accent        @rose;
@define-color main-br       @subtle;
@define-color main-bg       @base;
@define-color main-fg       @text;
@define-color hover-bg      @surface;
@define-color hover-fg      alpha(@main-fg, 0.75);
@define-color outline       shade(@main-bg, 0.5);

/* module colors */

@define-color workspaces    @surface;
@define-color temperature   @surface;
@define-color memory        @midpoint;
@define-color cpu           @overlay;
@define-color time          @overlay;
@define-color date          @midpoint;
@define-color tray          @base;
@define-color volume        @base;
@define-color backlight     @midpoint;
@define-color battery       @overlay;

/* state colors */

@define-color warning       @gold;
@define-color critical      @love;
@define-color charging      @pine;
