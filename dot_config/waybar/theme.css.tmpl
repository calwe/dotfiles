/* Generated by chezmoi — colors from active theme's waybar: block, layout from waybar.yaml */

{{- $has := hasKey . "waybar_waybar" }}
/* === Colors === */
@define-color bg    {{ if $has }}{{ .waybar_waybar.bg }}{{ else }}{{ .waybar.bg }}{{ end }};
@define-color text  {{ if $has }}{{ .waybar_waybar.text }}{{ else }}{{ .waybar.text }}{{ end }};
@define-color black {{ if $has }}{{ .waybar_waybar.black }}{{ else }}{{ .waybar.black }}{{ end }};
