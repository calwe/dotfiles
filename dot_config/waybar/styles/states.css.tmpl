/* Generated by chezmoi from .chezmoidata/waybar.yaml */

/*
 * State indication: invert colors (swap @bg / @text)
 * Warning and critical states use full color inversion for stark brutalist contrast.
 */

/* ---- warning state ---- */

#custom-cpu-stat.warning,
#custom-memory-stat.warning,
#battery.warning {
	background-color: @text;
	color: @bg;
	border-color: @black;
	box-shadow: {{ .waybar.shadow_size }} {{ .waybar.shadow_size }} 0 0 @black;
}

/* ---- critical state ---- */

#custom-cpu-stat.critical,
#custom-memory-stat.critical,
#custom-temp-stat.critical,
#battery.critical {
	background-color: @text;
	color: @bg;
	border-color: @black;
	box-shadow: {{ .waybar.shadow_size }} {{ .waybar.shadow_size }} 0 0 @black;
}

/* ---- charging state ---- */

#battery.charging {
	background-color: @text;
	color: @bg;
	border-color: @black;
	box-shadow: {{ .waybar.shadow_size }} {{ .waybar.shadow_size }} 0 0 @black;
}

/* ---- muted state ---- */

#pulseaudio.output.muted,
#pulseaudio.input.source-muted {
	background-color: @text;
	color: @bg;
	border-color: @black;
}
