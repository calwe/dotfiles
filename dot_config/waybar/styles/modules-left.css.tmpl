/* Generated by chezmoi from .chezmoidata/waybar.yaml */

/*------------------
    hostname
------------------*/

#custom-hostname {
	background-color: @bg;
	border: {{ .waybar.border_width }} solid @black;
	box-shadow: {{ .waybar.shadow_size }} {{ .waybar.shadow_size }} 0 0 @black;
	padding: 0 {{ .waybar.module_padding }};
	margin-top:    {{ .waybar.margin_v }}px;
	margin-bottom: {{ .waybar.margin_v }}px;
	margin-left:   {{ .waybar.margin_h }}px;
	margin-right:  {{ .waybar.margin_h }}px;
	font-weight: {{ .waybar.font_weight_bold }};
}

/*----------------
    workspaces
----------------*/

/* Outer wrapper — invisible, provides margin_h gap from neighbours */
#workspaces {
	background-color: transparent;
	border: none;
	box-shadow: none;
	padding: 0;
	margin-top:    0;
	margin-bottom: 0;
	margin-left:   {{ .waybar.margin_h }}px;
	margin-right:  {{ .waybar.margin_h }}px;
}

/* Each workspace button — grouped item: uses margin_grouped_v/h as base for shift math */
#workspaces button {
	background-color: @bg;
	border: {{ .waybar.border_width }} solid @black;
	box-shadow: {{ .waybar.shadow_size }} {{ .waybar.shadow_size }} 0 0 @black;
	padding: 0 {{ .waybar.grouped_padding }};
	margin-top:    {{ .waybar.margin_grouped_v }}px;
	margin-bottom: {{ .waybar.margin_grouped_v }}px;
	margin-left:   {{ .waybar.margin_grouped_h }}px;
	margin-right:  {{ .waybar.margin_grouped_h }}px;
	font-weight: {{ .waybar.font_weight_normal }};
	color: @text;
	border-radius: 0;
	min-width: 0;
}

/* Hover: shift up-left using grouped base margins, total space unchanged */
#workspaces button:hover {
	background-color: @bg;
	box-shadow: {{ .waybar.shadow_hover_size }} {{ .waybar.shadow_hover_size }} 0 0 @black;
	margin-top:    {{ sub .waybar.margin_grouped_v .waybar.shift_amount }}px;
	margin-bottom: {{ add .waybar.margin_grouped_v .waybar.shift_amount }}px;
	margin-left:   {{ sub .waybar.margin_grouped_h .waybar.shift_amount }}px;
	margin-right:  {{ add .waybar.margin_grouped_h .waybar.shift_amount }}px;
}

/* Active workspace = pressed state: shift down-right, total space unchanged */
#workspaces button.active {
	background-color: @bg;
	box-shadow: none;
	border: {{ .waybar.border_width }} solid @black;
	margin-top:    {{ add .waybar.margin_grouped_v .waybar.shift_amount }}px;
	margin-bottom: {{ sub .waybar.margin_grouped_v .waybar.shift_amount }}px;
	margin-left:   {{ add .waybar.margin_grouped_h .waybar.shift_amount }}px;
	margin-right:  {{ sub .waybar.margin_grouped_h .waybar.shift_amount }}px;
	font-weight: {{ .waybar.font_weight_bold }};
}

/*--------------------
    column position
--------------------*/

#custom-niri-column-pos {
	background-color: @bg;
	border: {{ .waybar.border_width }} solid @black;
	box-shadow: {{ .waybar.shadow_size }} {{ .waybar.shadow_size }} 0 0 @black;
	padding: 0 {{ .waybar.module_padding }};
	margin-top:    {{ .waybar.margin_v }}px;
	margin-bottom: {{ .waybar.margin_v }}px;
	margin-left:   {{ .waybar.margin_h }}px;
	margin-right:  {{ .waybar.margin_h }}px;
}

/*------------------
    window title
------------------*/

#window {
	background-color: @bg;
	border: {{ .waybar.border_width }} solid @black;
	box-shadow: {{ .waybar.shadow_size }} {{ .waybar.shadow_size }} 0 0 @black;
	padding: 0 {{ .waybar.module_padding }};
	margin-top:    {{ .waybar.margin_v }}px;
	margin-bottom: {{ .waybar.margin_v }}px;
	margin-left:   {{ .waybar.margin_h }}px;
	margin-right:  {{ .waybar.margin_h }}px;
	font-weight: {{ .waybar.font_weight_normal }};
}
