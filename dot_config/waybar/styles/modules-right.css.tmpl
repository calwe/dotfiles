/* Generated by chezmoi from .chezmoidata/waybar.yaml */

/*----------------
    media (mpris)
----------------*/

#mpris {
	background-color: @bg;
	border: {{ .waybar.border_width }} solid @black;
	box-shadow: {{ .waybar.shadow_size }} {{ .waybar.shadow_size }} 0 0 @black;
	padding: 0 {{ .waybar.module_padding }};
	margin-top:    {{ .waybar.margin_v }}px;
	margin-bottom: {{ .waybar.margin_v }}px;
	margin-left:   {{ .waybar.margin_h }}px;
	margin-right:  {{ .waybar.margin_h }}px;
	font-weight: {{ .waybar.font_weight_normal }};
}

/*--------------------------
    stats group (cpu/mem/temp)
--------------------------*/

/* Grouped items: margin_grouped_v/h as base */
#custom-cpu-stat,
#custom-memory-stat,
#custom-temp-stat {
	background-color: @bg;
	border: {{ .waybar.border_width }} solid @black;
	box-shadow: {{ .waybar.shadow_size }} {{ .waybar.shadow_size }} 0 0 @black;
	padding: 0 {{ .waybar.grouped_padding }};
	margin-top:    {{ .waybar.margin_grouped_v }}px;
	margin-bottom: {{ .waybar.margin_grouped_v }}px;
	margin-left:   {{ .waybar.margin_grouped_h }}px;
	margin-right:  {{ .waybar.margin_grouped_h }}px;
	font-weight: {{ .waybar.font_weight_normal }};
}

/* Left/right edges of the group get standalone margin_h to space from neighbours */
#custom-cpu-stat {
	margin-left: {{ .waybar.margin_h }}px;
}

#custom-temp-stat {
	margin-right: {{ .waybar.margin_h }}px;
}

