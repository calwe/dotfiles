/* Generated by chezmoi from .chezmoidata/waybar.yaml */

/*
 * Brutalist design rules:
 *   border:           {{ .waybar.border_width }} solid @black
 *   shadow-normal:    {{ .waybar.shadow_size }} {{ .waybar.shadow_size }} 0 0 @black
 *   shadow-hover:     {{ .waybar.shadow_hover_size }} {{ .waybar.shadow_hover_size }} 0 0 @black
 *   shadow-pressed:   none
 *   module_padding:   {{ .waybar.module_padding }} (internal left/right padding inside box)
 *   grouped_padding:  {{ .waybar.grouped_padding }} (internal padding for grouped items)
 *   margin_v/margin_h: {{ .waybar.margin_v }}px / {{ .waybar.margin_h }}px (standalone module gaps)
 *   margin_grouped_v/h: {{ .waybar.margin_grouped_v }}px / {{ .waybar.margin_grouped_h }}px (in-group gaps)
 *   shift_amount:     {{ .waybar.shift_amount }}px (hover/press movement)
 *
 * Hover math (standalone):  element shifts up-left, total occupied space unchanged
 *   margin-top:    (margin_v - shift_amount)px
 *   margin-bottom: (margin_v + shift_amount)px
 *   margin-left:   (margin_h - shift_amount)px
 *   margin-right:  (margin_h + shift_amount)px
 *
 * Press math (standalone):  element shifts down-right, total occupied space unchanged
 *   margin-top:    (margin_v + shift_amount)px
 *   margin-bottom: (margin_v - shift_amount)px
 *   margin-left:   (margin_h + shift_amount)px
 *   margin-right:  (margin_h - shift_amount)px
 */

* {
	border-radius: 0;
	min-height: 0;
}

#waybar {
	background-color: @bg;
	border: none;
}

#waybar > box {
	margin-top:    {{ .waybar.bar_margin_top }}px;
	margin-right:  {{ .waybar.bar_margin_right }}px;
	margin-bottom: {{ .waybar.bar_margin_bottom }}px;
	margin-left:   {{ .waybar.bar_margin_left }}px;
	background-color: @bg;
}

/* ---- Brutalist container base ---- */

.brutalist {
	background-color: @bg;
	border: {{ .waybar.border_width }} solid @black;
	box-shadow: {{ .waybar.shadow_size }} {{ .waybar.shadow_size }} 0 0 @black;
	padding: 0 {{ .waybar.module_padding }};
	margin-top:    {{ .waybar.margin_v }}px;
	margin-bottom: {{ .waybar.margin_v }}px;
	margin-left:   {{ .waybar.margin_h }}px;
	margin-right:  {{ .waybar.margin_h }}px;
}

/* ---- Brutalist button interactions ---- */

button.brutalist:hover {
	background-color: @bg;
	margin-top:    {{ sub .waybar.margin_v .waybar.shift_amount }}px;
	margin-bottom: {{ add .waybar.margin_v .waybar.shift_amount }}px;
	margin-left:   {{ sub .waybar.margin_h .waybar.shift_amount }}px;
	margin-right:  {{ add .waybar.margin_h .waybar.shift_amount }}px;
	box-shadow: {{ .waybar.shadow_hover_size }} {{ .waybar.shadow_hover_size }} 0 0 @black;
}

button.brutalist:active {
	background-color: @bg;
	margin-top:    {{ add .waybar.margin_v .waybar.shift_amount }}px;
	margin-bottom: {{ sub .waybar.margin_v .waybar.shift_amount }}px;
	margin-left:   {{ add .waybar.margin_h .waybar.shift_amount }}px;
	margin-right:  {{ sub .waybar.margin_h .waybar.shift_amount }}px;
	box-shadow: none;
	border: {{ .waybar.border_width }} solid @black;
}

/* ---- Tooltip ---- */

tooltip {
	background-color: @bg;
	border: {{ .waybar.border_width }} solid @black;
	box-shadow: {{ .waybar.shadow_size }} {{ .waybar.shadow_size }} 0 0 @black;
	border-radius: 0;
}

tooltip label {
	color: @text;
	font-weight: {{ .waybar.font_weight_normal }};
}
